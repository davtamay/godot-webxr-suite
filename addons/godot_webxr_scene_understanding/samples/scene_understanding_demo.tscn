theme_override_colors/font_color = Color(0.62, 0.66, 0.72, 1)
autowrap_mode = 3
text = "WebXR features: Room Mesh & Live Recon -> mesh-detection. Depth Scan -> depth-sensing (live per-frame depth, even a moving hand; never a saved map). Scene Labels -> plane-detection. Show = draw it; Occlude = hide virtual content behind it."

